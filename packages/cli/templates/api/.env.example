--------------------------------------------------

Najumi API Environment Configuration

--------------------------------------------------

Application

APP_NAME={{projectName}}
APP_ENV=development
APP_PORT=3000

--------------------------------------------------

Database (Najumi Atlas)

--------------------------------------------------

DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://user:password@localhost:5432/{{projectName}}

--------------------------------------------------

Authentication

--------------------------------------------------

JWT_SECRET=change_this_secret_key
SESSION_SECRET=change_this_session_secret

--------------------------------------------------

API Security

--------------------------------------------------

API_RATE_LIMIT=100
API_RATE_WINDOW=60

--------------------------------------------------

Cache (Najumi Pulse)

--------------------------------------------------

CACHE_DRIVER=memory

--------------------------------------------------

Queue (Najumi Orbit)

--------------------------------------------------

QUEUE_DRIVER=memory

--------------------------------------------------

Logging

--------------------------------------------------

LOG_LEVEL=info

--------------------------------------------------

External Services (Optional)

--------------------------------------------------

OAuth providers example

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

--------------------------------------------------

Storage (Optional)

--------------------------------------------------

STORAGE_DRIVER=local
STORAGE_PATH=./storage