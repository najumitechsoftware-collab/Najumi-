{
"name": "api",
"displayName": "Najumi API Server",
"description": "Starter template for building a backend API service with Najumi.js",
"type": "backend",
"version": "1.0.0",
"framework": "najumi",
"minimumNajumiVersion": "1.0.0",

"features": [
"backend",
"api",
"services",
"authentication-ready",
"database-ready"
],

"structure": {
"src/api": "API route handlers",
