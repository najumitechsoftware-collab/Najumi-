--------------------------------------------------

Najumi Dashboard Environment Configuration

--------------------------------------------------

Application

APP_NAME={{projectName}}
APP_ENV=development
APP_PORT=3000

--------------------------------------------------

Authentication

--------------------------------------------------

JWT_SECRET=change_this_secret
SESSION_SECRET=change_this_session_secret

--------------------------------------------------

Dashboard Settings

--------------------------------------------------

DASHBOARD_TITLE={{projectName}} Dashboard
DASHBOARD_ANALYTICS=true

--------------------------------------------------

API Endpoint

--------------------------------------------------

API_BASE_URL=http://localhost:3000/api

--------------------------------------------------

Analytics (Optional)

--------------------------------------------------

ANALYTICS_PROVIDER=internal

--------------------------------------------------

Logging

--------------------------------------------------

LOG_LEVEL=info

--------------------------------------------------

Security

--------------------------------------------------

CORS_ENABLED=true
API_RATE_LIMIT=100
API_RATE_WINDOW=60