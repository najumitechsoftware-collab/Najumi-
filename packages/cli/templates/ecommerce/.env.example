--------------------------------------------------

Najumi Ecommerce Environment Configuration

--------------------------------------------------

Application

APP_NAME={{projectName}}
APP_ENV=development
APP_PORT=3000

--------------------------------------------------

Store Settings

--------------------------------------------------

STORE_NAME={{projectName}}
STORE_CURRENCY=USD
STORE_SUPPORT_EMAIL=support@example.com

--------------------------------------------------

API Configuration

--------------------------------------------------

API_BASE_URL=http://localhost:3000/api

--------------------------------------------------

Payment Providers (Optional)

--------------------------------------------------

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

--------------------------------------------------

Cart Settings

--------------------------------------------------

CART_STORAGE=session

--------------------------------------------------

Logging

--------------------------------------------------

LOG_LEVEL=info

--------------------------------------------------

Security

--------------------------------------------------

CORS_ENABLED=true
API_RATE_LIMIT=100
API_RATE_WINDOW=60