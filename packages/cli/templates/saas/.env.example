--------------------------------------------------

Najumi SaaS Environment Configuration

--------------------------------------------------

Application

APP_NAME={{projectName}}
APP_ENV=development
APP_PORT=3000

--------------------------------------------------

Database (Najumi Atlas)

--------------------------------------------------

DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://user:password@localhost:5432/{{projectName}}

--------------------------------------------------

Authentication

--------------------------------------------------

JWT_SECRET=change_this_jwt_secret
SESSION_SECRET=change_this_session_secret

--------------------------------------------------

SaaS Settings

--------------------------------------------------

SAAS_APP_URL=http://localhost:3000
SAAS_SUPPORT_EMAIL=support@example.com

--------------------------------------------------

OAuth Providers (Optional)

--------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

--------------------------------------------------

Storage (Najumi Harbor)

--------------------------------------------------

STORAGE_DRIVER=local
STORAGE_PATH=./storage

--------------------------------------------------

Cache (Najumi Pulse)

--------------------------------------------------

CACHE_DRIVER=memory

--------------------------------------------------

Queue (Najumi Orbit)

--------------------------------------------------

QUEUE_DRIVER=memory

--------------------------------------------------

Logging

--------------------------------------------------

LOG_LEVEL=info

--------------------------------------------------

Security

--------------------------------------------------

API_RATE_LIMIT=100
API_RATE_WINDOW=60